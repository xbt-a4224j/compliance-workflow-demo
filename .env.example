# Copy to .env and fill in. .env is gitignored.

# --- API auth ---
# Required. Every non-/health request must carry
#   Authorization: Bearer <AUTH_TOKEN>
# The frontend prompts for this on first load and stores it in localStorage.
# The API refuses to start if AUTH_TOKEN is empty.
AUTH_TOKEN=

# Optional: comma-separated CORS allowlist. Defaults to localhost dev ports.
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# --- LLM providers ---
# Required for live LLM runs. Without these, the demo CLI falls back to a
# mock adapter that answers from the violation matrix.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional model overrides. Defaults are sensible.
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_MODEL=gpt-4o-mini

# --- Database ---
# Defaults to the docker-compose Postgres at localhost:5432.
# DATABASE_URL=postgresql://compliance:compliance@localhost:5432/compliance

# --- OTel ---
# Defaults to the docker-compose Jaeger at localhost:4317.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
